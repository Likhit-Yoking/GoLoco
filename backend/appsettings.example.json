{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "YOUR_SQL_CONNECTION_STRING"
  },
  "AzureBlobStorage": {
    "ConnectionString": "YOUR_BLOB_CONNECTION_STRING",
    "ContainerName": "event-images"
  },
  "Jwt": {
    "Key": "YOUR_JWT_SECRET_KEY",
    "Issuer": "localhost",
    "Audience": "localhost"
  }
}
